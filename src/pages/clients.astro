---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Client Portfolio & Case Studies | Livia Makes Perfect"
  description="See the brands we've helped grow: InvestMindset, Novamil, Mittal Institute, Hotwax, iWoman TV and more. Real results from a real digital agency."
  keywords="digital marketing portfolio, client case studies, RevOps results, social media growth, Meta Ads results"
  canonicalUrl="https://liviamperfect.web.app/clients"
>
  <section class="page-hero container fade-in">
    <p class="section-label">Our Portfolio</p>
    <h1>Brands We've <span class="text-brand">Helped Grow</span></h1>
    <p>From early-stage startups to established enterprises — we've delivered measurable results across industries.</p>
  </section>

  <!-- Stats -->
  <section class="section-sm container fade-in">
    <div style="display:grid;gap:2rem;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));text-align:center;margin-bottom:4rem;">
      <div style="background:#fff;border:1px solid var(--border);border-radius:20px;padding:2rem;">
        <div style="font-size:2.5rem;font-weight:700;color:var(--brand);font-family:'Inter',sans-serif;">20+</div>
        <div style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">Clients Served</div>
      </div>
      <div style="background:#fff;border:1px solid var(--border);border-radius:20px;padding:2rem;">
        <div style="font-size:2.5rem;font-weight:700;color:var(--brand);font-family:'Inter',sans-serif;">3.2x</div>
        <div style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">Avg. ROI Increase</div>
      </div>
      <div style="background:#fff;border:1px solid var(--border);border-radius:20px;padding:2rem;">
        <div style="font-size:2.5rem;font-weight:700;color:var(--brand);font-family:'Inter',sans-serif;">5</div>
        <div style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">Industries Covered</div>
      </div>
      <div style="background:#fff;border:1px solid var(--border);border-radius:20px;padding:2rem;">
        <div style="font-size:2.5rem;font-weight:700;color:var(--brand);font-family:'Inter',sans-serif;">NRF</div>
        <div style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">Featured at NY, USA</div>
      </div>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="section container fade-in">
    <div class="portfolio-grid">
      <div class="portfolio-card">
        <div class="portfolio-thumb" style="background:#fef2f5;">
          <span class="portfolio-tag">RevOps</span>
          <span style="font-size:2rem;">🏦</span>
        </div>
        <div class="portfolio-body">
          <h4>InvestMindset</h4>
          <p>HubSpot CRM setup, pipeline automation, and email nurture sequences that boosted conversions 2.8x.</p>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-thumb" style="background:#f0faf5;">
          <span class="portfolio-tag">Social Media</span>
          <span style="font-size:2rem;">🌿</span>
        </div>
        <div class="portfolio-body">
          <h4>Novamil</h4>
          <p>End-to-end social media management with content strategy, growing their audience by 150% in 6 months.</p>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-thumb" style="background:#f5f0ff;">
          <span class="portfolio-tag">Branding</span>
          <span style="font-size:2rem;">🎓</span>
        </div>
        <div class="portfolio-body">
          <h4>Mittal Institute</h4>
          <p>Full brand identity refresh, new logo, presentation decks, and digital collateral for institute launch.</p>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-thumb" style="background:#fff5ee;">
          <span class="portfolio-tag">Video</span>
          <span style="font-size:2rem;">🏡</span>
        </div>
        <div class="portfolio-body">
          <h4>Shishupuram</h4>
          <p>Promotional video production and motion graphics that drove a 40% increase in online enquiries.</p>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-thumb" style="background:#f0f4ff;">
          <span class="portfolio-tag">Performance Ads</span>
          <span style="font-size:2rem;">🛒</span>
        </div>
        <div class="portfolio-body">
          <h4>Hotwax</h4>
          <p>Meta & Google Ads campaigns achieving a 3.5x ROAS with targeted lookalike audience strategies.</p>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-thumb" style="background:#fff0f8;">
          <span class="portfolio-tag">Content + Video</span>
          <span style="font-size:2rem;">📺</span>
        </div>
        <div class="portfolio-body">
          <h4>iWoman TV</h4>
          <p>Content creation, video editing, and social media management for a leading women's media channel.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section fade-in">
    <div class="container">
      <p class="section-label">Work With Us</p>
      <h2>Let's add you to this list</h2>
      <p>Every great result started with a single conversation. Let's have ours.</p>
      <div style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary btn-lg">Get a Quote</a>
      </div>
    </div>
  </section>
</Layout>
