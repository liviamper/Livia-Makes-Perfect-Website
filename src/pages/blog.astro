---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all posts from the blog collection
const blogEntries = await getCollection('blog');

// Sort by date descending
const posts = blogEntries.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const defaultImage = "/assets/images/social.png";
---

<Layout 
  title="Blog & Digital Marketing Insights | Livia Makes Perfect"
  description="Actionable strategies on RevOps, Meta Ads, HubSpot, social media growth and content marketing from the Livia Makes Perfect agency team."
  keywords="digital marketing blog, RevOps tips, Meta Ads strategy, HubSpot tips, social media growth, content marketing"
  canonicalUrl="https://liviamperfect.web.app/blog"
>
  <section class="page-hero container fade-in">
    <p class="section-label">Insights & Ideas</p>
    <h1>Digital <span class="text-brand">Insights</span></h1>
    <p>Actionable strategies, marketing trends, and deep-dives into RevOps and performance advertising.</p>
  </section>

  <section class="section container fade-in">
    <div class="blog-grid">
      {posts.map(post => (
        <article class="blog-card">
          <div class="blog-thumb" style="position: relative; overflow: hidden; border-radius: 12px; height: 200px; background: #f8f9fa;">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} style="width:100%; height:100%; object-fit:cover;" />
            ) : (
              <div style="font-size:3.5rem; display:flex; align-items:center; justify-content:center; height:100%; width:100%;">{post.data.icon || '📝'}</div>
            )}
            <div class="blog-tag" style="position:absolute; top:12px; left:12px; background: var(--brand); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">{post.data.tag}</div>
          </div>
          <div class="blog-body">
            <p class="section-label" style="font-size:0.75rem; margin-bottom:0.5rem;">{new Date(post.data.date).toLocaleDateString()} • {post.data.author}</p>
            <h4 style="margin-top:0;">{post.data.title}</h4>
            <p>{post.data.description}</p>
            <a href={`/blog/${post.id}`} class="blog-link">Read Article →</a>
          </div>
        </article>
      ))}
      
      {posts.length === 0 && (
        <p class="text-center" style="grid-column: 1 / -1; color: var(--text-muted);">
          No posts yet. Check back soon for more insights!
        </p>
      )}
    </div>
  </section>

  <section class="cta-section fade-in">
    <div class="container">
      <p class="section-label">Scale Your Business</p>
      <h2>Ready to grow?</h2>
      <p>Let's turn these insights into action for your business.</p>
      <a href="/contact" class="btn btn-primary btn-lg">Get a Quote</a>
    </div>
  </section>
</Layout>
