---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => {
    // Strip the date prefix (YYYY-MM-DD-) from the slug for clean URLs
    const cleanSlug = entry.id.replace(/^\d{4}-\d{2}-\d{2}-/, '');
    return {
      params: { slug: cleanSlug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Filter headings for the TOC (only h2 and h3)
const tocItems = headings.filter(h => h.depth >= 2 && h.depth <= 3);

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.description,
  "image": entry.data.image ? `https://liviamperfect.web.app${entry.data.image}` : "https://liviamperfect.web.app/assets/images/social.png",
  "author": {
    "@type": "Organization",
    "name": "Livia Makes Perfect"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Livia Makes Perfect",
    "logo": {
      "@type": "ImageObject",
      "url": "https://liviamperfect.web.app/assets/images/social.png"
    }
  },
  "datePublished": entry.data.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://liviamperfect.web.app/blog/${entry.id}`
  }
};
---

<Layout 
  title={`${entry.data.title} | Livia Makes Perfect`}
  description={entry.data.description}
  canonicalUrl={`https://liviamperfect.web.app/blog/${entry.id}`}
>
  <!-- SEO Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <article class="section container" style="max-width: 1200px;">
    <!-- Article Header -->
    <header class="text-center" style="margin-bottom: 4rem;">
      <p class="section-label">{entry.data.tag} • {new Date(entry.data.date).toLocaleDateString()}</p>
      <h1 class="hero-headline" style="font-size: clamp(2.5rem, 6vw, 4.5rem); margin-top: 1rem;">{entry.data.title}</h1>
      <p style="color: var(--text-muted); font-size: 1.25rem; max-width: 850px; margin: 1.2rem auto 2.5rem;">{entry.data.description}</p>
      
      <div style="display: flex; align-items: center; justify-content: center; gap: 1rem;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--brand); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem;">
          {entry.data.author.charAt(0)}
        </div>
        <div style="text-align: left;">
          <div style="font-weight: 700; font-size: 1.1rem; color: var(--text);">{entry.data.author}</div>
          <div style="font-size: 0.9rem; color: var(--text-muted);">Marketing Strategist</div>
        </div>
      </div>
    </header>

    <!-- Layout Container: Sidebar TOC + Content -->
    <div class="blog-layout">
      <!-- Desktop Sticky Sidebar -->
      <aside class="blog-sidebar desktop-only">
        {tocItems.length > 0 && (
          <div class="toc-container">
            <h5 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--brand); margin-bottom: 1.5rem; font-weight: 800;">
              Inside this Article
            </h5>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {tocItems.map(item => (
                <li style={`margin-bottom: 1rem; padding-left: ${item.depth === 3 ? '1.25rem' : '0'};`}>
                  <a href={`#${item.slug}`} style="font-size: 0.95rem; color: var(--text-muted); font-weight: 500; transition: all 300ms ease; text-decoration: none; line-height: 1.4; display: block;" class="toc-link">
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        
        <!-- Sidebar CTA (Desktop Only) -->
        <div style="margin-top: 2rem; padding: 2rem; background: var(--text); color: white; border-radius: 20px; text-align: center;" class="sidebar-cta">
          <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--brand); font-weight: 700; margin-bottom: 1rem;">Livia Strategy</p>
          <h5 style="font-size: 1.2rem; margin-bottom: 1.5rem; line-height: 1.3;">Scale your performance marketing.</h5>
          <a href="/contact" style="display: block; background: var(--brand); color: white; text-decoration: none; padding: 0.8rem; border-radius: 8px; font-weight: 700; font-size: 0.9rem;">Get Started</a>
        </div>
      </aside>

      <!-- Main Article Column -->
      <div class="blog-main-content">
        <!-- Mobile-Only TOC -->
        {tocItems.length > 0 && (
          <div class="mobile-only" style="margin-bottom: 2.5rem;">
            <details class="toc-container">
              <summary style="font-size: 0.9rem; font-weight: 700; color: var(--brand); cursor: pointer; display: flex; align-items: center; justify-content: space-between; list-style: none;">
                Table of Contents
                <span class="toc-toggle-icon" style="font-size: 0.7rem;">▼</span>
              </summary>
              <ul style="list-style: none; padding: 0; margin: 1.5rem 0 0 0; border-top: 1px solid var(--border); padding-top: 1rem;">
                {tocItems.map(item => (
                  <li style={`margin-bottom: 0.75rem; padding-left: ${item.depth === 3 ? '1.25rem' : '0'};`}>
                    <a href={`#${item.slug}`} style="font-size: 0.95rem; color: var(--text-muted); text-decoration: none;" class="toc-link">
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          </div>
        )}

        <!-- Featured Image -->
        {entry.data.image && (
          <div style="margin-bottom: 3.5rem; border-radius: 24px; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 10px 40px rgba(0,0,0,0.03);">
            <img src={entry.data.image} alt={entry.data.title} style="width: 100%; height: auto; display: block;" />
          </div>
        )}

        <!-- Content Body -->
        <div class="blog-content">
          <Content />
        </div>

        <!-- Article Footer / CTA -->
        <div style="margin-top: 6rem; padding: 4rem 2rem; background: #fdfdfd; border: 1px solid var(--border); border-radius: 30px; text-align: center;">
          <p class="section-label">Ready to Grow?</p>
          <h3 style="font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 1.5rem; line-height: 1.2;">Let's apply these strategies to your business</h3>
          <p style="margin-bottom: 3rem; color: var(--text-muted); max-width: 550px; margin-left: auto; margin-right: auto; font-size: 1.1rem;">Schedule a free 15-minute consultation with the Livia Team to audit your current performance advertising.</p>
          <div style="display:flex; gap: 1rem; justify-content:center; flex-wrap:wrap;">
            <a href="/contact" class="btn btn-primary btn-lg">Get a Quote</a>
            <a href="mailto:liviamper@gmail.com" class="btn btn-outline btn-lg">Contact Agent</a>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  /* Blog Layout Responsive Grid */
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .desktop-only { display: none; }
  .mobile-only { display: block; }

  @media (min-width: 900px) {
    .blog-layout {
      grid-template-columns: 320px 1fr;
      gap: 4rem;
      align-items: start;
    }
    .blog-sidebar {
      position: sticky;
      top: 120px;
    }
    .desktop-only { display: block; }
    .mobile-only { display: none; }
  }

  .toc-container {
    background: #fdfdfd;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 1.5rem 2rem;
  }
  
  .toc-container summary::-webkit-details-marker {
    display: none;
  }
  .toc-container[open] .toc-toggle-icon {
    transform: rotate(180deg);
  }
  .toc-toggle-icon {
    transition: transform 300ms ease;
  }
  /* Premium typography for blog posts */
  .blog-content {
    color: #333;
    font-size: clamp(1.1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    padding: 0 5%; /* Adds safe padding on mobile */
  }

  @media (min-width: 900px) {
    .blog-content {
      padding: 0; /* Remove extra padding on desktop as it's in a grid */
      font-size: 1.25rem;
    }
  }

  .blog-content h2 { 
    margin: 4rem 0 2rem; 
    font-size: clamp(1.8rem, 5vw, 2.4rem); 
    font-weight: 700;
    line-height: 1.2;
  }
  .blog-content h3 { 
    margin: 3rem 0 1.5rem; 
    font-size: clamp(1.5rem, 4vw, 1.9rem);
    font-weight: 600;
  }
  .blog-content p { 
    margin-bottom: 2rem; 
  }
  .blog-content ul, .blog-content ol { 
    margin-bottom: 2rem; 
    padding-left: 1.5rem; 
  }
  .blog-content li { 
    margin-bottom: 0.75rem; 
  }
  .blog-content strong { 
    color: var(--brand); 
    font-weight: 700;
  }
  .blog-content blockquote {
    border-left: 4px solid var(--brand);
    padding: 1.5rem 2rem;
    margin: 3rem 0;
    background: #f9f9f9;
    font-style: italic;
    font-size: 1.4rem;
    color: #555;
    border-radius: 0 10px 10px 0;
  }
  .blog-content img {
    border-radius: 15px;
    margin: 3rem 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }
</style>
