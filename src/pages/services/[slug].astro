---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const services = [
    {
      slug: 'revenue-operations',
      title: 'Revenue Operations (RevOps)',
      icon: '📈',
      description: 'Stop guessing. Start growing. We align your data, tech, and teams into a single, scalable source of truth.',
      longDescription: 'Revenue Operations is the engine of predictable growth. At Livia Makes Perfect, we don’t just fix tools; we engineer the strategic integration of sales, marketing, and customer success to eliminate silos and maximize lifecycle value.',
      features: [
        'HubSpot & Salesforce Architecture Audit',
        'Cross-Functional Process Optimization',
        'Data Integrity & Unified Reporting',
        'Automated Lead Lifecycle Design',
        'Predictable Forecasting Models'
      ],
      process: [
        { title: 'The Audit', desc: 'A deep-dive into your RevOps maturity and tech-stack bottlenecks.' },
        { title: 'The Alignment', desc: 'Standardizing definitions and data across the entire funnel.' },
        { title: 'The Optimization', desc: 'Deploying high-impact workflows that drive measurable growth.' }
      ]
    },
    {
      slug: 'graphics-designing',
      title: 'Graphics & Creative Branding',
      icon: '🎨',
      description: 'Visual authority meets aesthetic ROI. Design that commands attention and converts intent into action.',
      longDescription: 'Your visual identity is your definitive edge in a crowded market. Our design system approach ensures that every pixel is engineered to communicate your brand values and trigger conversion.',
      features: [
        'Complete Brand Identity Systems',
        'High-Conversion Ad Creative',
        'Investor Pitch Decks & Sales Collateral',
        'Custom Iconography & Illustrations',
        'Aesthetic Social Media Kits'
      ],
      process: [
        { title: 'Brand Blueprint', desc: 'Defining your visual voice and competitive positioning.' },
        { title: 'System Creation', desc: 'Developing a cohesive design ecosystem, not just a logo.' },
        { title: 'Asset Deployment', desc: 'Exporting optimized, ready-to-use visuals for every platform.' }
      ]
    },
    {
      slug: 'video-animations',
      title: 'Cinematic Video & Animation',
      icon: '🎬',
      description: 'Scroll-stopping narratives engineered for the social-first era. Cinematic velocity that builds deep brand affinity.',
      longDescription: 'In a world of 3-second attention spans, we create video content that builds deep brand trust. By combining cinematic storytelling with AI-enhanced motion design, we deliver high-retention video assets.',
      features: [
        'Brand Narrative & Storytelling',
        'AI-Enhanced Motion Illustrations',
        'High-Impact Product Teasers',
        'Vertical Video Social-First Ads',
        'Post-Production & Sound Design'
      ],
      process: [
        { title: 'Script-First', desc: 'Crafting a hook-focused narrative that speaks to core user pain.' },
        { title: 'Production', desc: 'Cinematic filming and intricate motion design execution.' },
        { title: 'The Cut', desc: 'High-energy editing optimized for specific social platform algorithms.' }
      ]
    },
    {
      slug: 'social-media-management',
      title: 'Social Media Strategy',
      icon: '📣',
      description: 'Building momentum and winning mindshare. We turn passive followers into active brand advocates.',
      longDescription: 'Social media is your brand’s storefront and its greatest growth engine. We manage the entire lifecycle of your social presence, ensuring consistent engagement and ROI-driven community building.',
      features: [
        'Platform-Specific Content Strategy',
        'Active Community Management',
        'Influencer & Partner Collaboration',
        'Real-Time Viral Mechanics',
        'Advanced Social Listening & Insights'
      ],
      process: [
        { title: 'Channel Audit', desc: 'Mapping your current reach and identifying growth gaps.' },
        { title: 'Content Engine', desc: 'Curating a mix of educational, inspiring, and viral content.' },
        { title: 'Growth Mode', desc: 'Proactive engagement and amplification to scale your audience.' }
      ]
    },
    {
      slug: 'content-production',
      title: 'Authority Content Architecture',
      icon: '✍️',
      description: 'High-intent content that positions you as the definitive market leader. Architecture designed to educate and convert.',
      longDescription: 'Content is the fuel for your authority engine. We produce long-form, authoritative assets that don’t just rank on search engines—they establish your brand as the standard in your industry.',
      features: [
        'SEO Pillar Content & Whitepapers',
        'B2B Strategy Newsletters',
        'Interviews & Industry Case Studies',
        'Multi-Channel Content Atomization',
        'Strategic Editorial Management'
      ],
      process: [
        { title: 'Topic Mapping', desc: 'Finding high-intent keywords your audience is searching for.' },
        { title: 'Expert Creation', desc: 'Writing that reflects deep industry expertise and original research.' },
        { title: 'Amplification', desc: 'Repurposing one pillar piece into a month of social assets.' }
      ]
    },
    {
      slug: 'performance-ads',
      title: 'Performance & Growth Marketing',
      icon: '🚀',
      description: 'Precision scalability and limitless ROAS. Eliminating the guesswork in performance marketing.',
      longDescription: 'We don’t just run ads; we engineer scalable growth. By combining precision audience targeting with data-backed creative testing, we optimize for your bottom line, not just clicks.',
      features: [
        'Meta & Google Ads Engine',
        'B2B LinkedIn Lead Generation',
        'A/B Creative & Hook Testing',
        'Dynamic Retargeting Funnels',
        'Conversion Rate Optimization (CRO)'
      ],
      process: [
        { title: 'Audience Map', desc: 'Deep research into your target demographic and intent data.' },
        { title: 'Rapid Execution', desc: 'Launching and testing 30+ creative variations at once.' },
        { title: 'Scaling Phase', desc: 'Aggressively spending on winners to maximize your investment.' }
      ]
    }
  ];

  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout 
  title={`${service.title} | Livia Makes Perfect`}
  description={service.description}
  canonicalUrl={`https://liviamperfect.web.app/services/${service.slug}`}
>
  <div class="service-page">
    <section class="page-hero container">
      <p class="section-label">{service.icon} {service.title} Expertise</p>
      <h1>Scalable <span class="text-brand">{service.title}</span></h1>
      <p class="hero-sub">{service.longDescription}</p>
      <div style="margin-top: 2rem;">
        <a href="/contact" class="btn btn-primary btn-lg">Get a Free {service.title} Audit</a>
      </div>
    </section>

    <section class="section container">
      <div class="service-details-grid">
        <div class="details-content fade-in">
          <h2>Core Capabilities</h2>
          <ul class="features-list">
            {service.features.map(feature => (
              <li>
                <span class="check">✓</span>
                <span class="feature-text">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="details-process fade-in">
          <h2>Our 3-Step Process</h2>
          <div class="process-steps">
            {service.process.map((step, index) => (
              <div class="step-card">
                <div class="step-num">0{index + 1}</div>
                <h4>{step.title}</h4>
                <p>{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section fade-in">
      <div class="container">
        <h2>Want to boost your {service.title} results?</h2>
        <p>Let's talk about your current bottlenecks and build a plan to solve them.</p>
        <div style="margin-top: 2rem;">
          <a href="/contact" class="btn btn-primary btn-lg">Book a Free {service.title} Audit</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .service-page {
    padding-bottom: 2rem;
  }
  .hero-sub {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 800px;
    margin: 1rem auto 0;
  }
  .service-details-grid {
    display: grid;
    gap: 4rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .service-details-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .features-list {
    margin-top: 2rem;
    display: grid;
    gap: 1.25rem;
  }
  .features-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-size: 1.1rem;
    color: var(--text-muted);
  }
  .feature-text {
    line-height: 1.4;
    padding-top: 2px;
  }
  .check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--brand);
    color: white;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: bold;
    flex-shrink: 0;
  }
  .process-steps {
    display: grid;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .step-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    position: relative;
    padding-left: 4.5rem;
  }
  @media (max-width: 500px) {
    .step-card {
      padding-left: 1.5rem;
      padding-top: 4rem;
    }
  }
  .step-num {
    position: absolute;
    left: 1.5rem;
    top: 1.5rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--brand);
    opacity: 0.3;
  }
  .step-card h4 {
    margin-bottom: 0.5rem;
  }
  .step-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>
