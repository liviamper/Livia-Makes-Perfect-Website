---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Thank You | Livia Makes Perfect"
  description="Thank you for contacting Livia Makes Perfect. We will be in touch shortly."
>
  <section class="container fade-in" style="min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center;">
    <div>
      <div style="font-size: 4rem; margin-bottom: 1.5rem;">✅</div>
      <p class="section-label">We received your message</p>
      <h1>Thank You!</h1>
      <p style="color:var(--text-muted);font-size:1.1rem;max-width:500px;margin:1rem auto 2.5rem;">Your inquiry has been submitted. The Livia Makes Perfect team will get back to you within <strong>24 hours</strong>.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/services" class="btn btn-outline">Explore Services</a>
      </div>
    </div>
  </section>
</Layout>
