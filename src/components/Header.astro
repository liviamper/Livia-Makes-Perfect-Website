---
const pathname = Astro.url.pathname;
const currentPath = pathname.slice(1); // remove the leading slash
---
<header class="site-header">
  <div class="container">
    <a href="/" class="logo"><span>Livia</span> Makes Perfect</a>
    <button class="mobile-menu-btn" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
    <nav class="main-nav">
      <a href="/services" class={currentPath === 'services' ? 'active' : ''}>Services</a>
      <a href="/clients" class={currentPath === 'clients' ? 'active' : ''}>Clients</a>
      <a href="/blog" class={currentPath.startsWith('blog') ? 'active' : ''}>Blog</a>
      <a href="/contact" class={currentPath === 'contact' ? 'active' : ''}>Contact</a>
      <a href="/contact" class="btn btn-primary mobile-only-btn">Get a Quote</a>
    </nav>
    <a href="/contact" class="btn btn-primary desktop-only-btn">Get a Quote</a>
  </div>
</header>

<script>
  const btn = document.querySelector('.mobile-menu-btn');
  const nav = document.querySelector('.main-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      nav.classList.toggle('active');
    });
  }
</script>
